{
  "name": "image-studio-alignment",
  "version": "1.0.0",
  "description": "Cross-platform ImageStudio blot alignment automation",
  "private": false,
  "bin": {
    "image-studio": "image_studio_cli.js"
  },
  "scripts": {
    "postinstall": "python3 -m venv .venv && .venv/bin/pip install -r requirements.txt",
    "image-studio": "node image_studio_cli.js run",
    "detect": "node image_studio_cli.js detect",
    "targets": "node image_studio_cli.js prepare",
    "align": "node image_studio_cli.js align",
    "verify": "node image_studio_cli.js verify",
    "complete": "node image_studio_cli.js complete"
  },
  "engines": {
    "node": ">=14"
  }
}
